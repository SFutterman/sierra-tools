#!/usr/bin/env bash
# Launch Sierra's Velocity TUI
set -e

VELOCITY_DIR="$HOME/Tuning/Current"
TUI="$VELOCITY_DIR/velocity_tui.py"

if ! command -v python3 &>/dev/null; then
    echo "❌ python3 not found"
    exit 1
fi

python3 -c "import textual" 2>/dev/null || {
    echo "📦 Installing textual..."
    pip3 install textual
}

if [ ! -f "$TUI" ]; then
    echo "❌ velocity_tui.py not found at $TUI"
    exit 1
fi

cd "$VELOCITY_DIR"
exec python3 "$TUI"
